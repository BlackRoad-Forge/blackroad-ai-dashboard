# ─── Raspberry Pi Device Addresses ────────────────────────────────────────────
# Point these to your Pi's running Ollama (default port 11434)
PI_LUCIDIA_HOST=http://lucidia.local:11434
PI_CECILIA_HOST=http://cecilia.local:11434
PI_ARIA_HOST=http://aria.local:11434

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Create products/prices in Stripe Dashboard, then paste IDs here
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# Webhook secret from `stripe listen` CLI or Stripe Dashboard
STRIPE_WEBHOOK_SECRET=whsec_...
